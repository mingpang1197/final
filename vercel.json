{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run install:frontend && npm run build --prefix frontend && cp -r images frontend/dist/images",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/((?!api/|images/|assets/|favicon\\.svg).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{frontend/**,images/**,samples/**,data/**,scripts/**,.cursor/**,**/*.pdf,**/*.docx,**/*.md,node_modules/**}"
    }
  }
}
