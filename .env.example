# Upstage API (https://console.upstage.ai/)
UPSTAGE_API_KEY=

# Mock mode when API key is empty (uses sample text/responses)
# Vercel 배포 시 반드시 false 로 설정
MOCK_UPSTAGE=true

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# PDF 변환 (선택 — 서버 자동 PDF 다운로드용, Vercel에서는 보통 불필요)
# 로컬 Windows는 Word(docx2pdf)로 자동 변환. 클라우드는 브라우저 Print to PDF 사용.
# CONVERTAPI_SECRET=
